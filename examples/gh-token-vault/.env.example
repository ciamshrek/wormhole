# Auth0 Token Vault configuration
#
# Four Auth0 clients:
#
# 1. Agent Application (Native)
#    - Grant types: Device Code, Refresh Token
#    - Used by the agent container for headless authentication
#
# 2. Resource Client (linked to proxy API)
#    - Grant types: Token Exchange (federated-connection-access-token)
#    - Used by the proxy to call Token Vault
#
# 3. Connect App (Regular Web)
#    - Grant types: Authorization Code
#    - Companion app for Connected Accounts setup
#
# Plus:
#    - An API (Resource Server) representing the proxy, DPoP enforced
#    - A GitHub social connection with Token Vault enabled
#    - MRRT enabled at the tenant level

# Shared
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Agent app (Native) — device code flow
AUTH0_CLIENT_ID=agent-app-client-id
AUTH0_AUDIENCE=https://your-proxy-api-identifier

# Resource Client — Token Vault exchange
AUTH0_RESOURCE_CLIENT_ID=resource-client-id
AUTH0_RESOURCE_CLIENT_SECRET=resource-client-secret

# Connect companion app — Connected Accounts setup
CONNECT_CLIENT_ID=connect-app-client-id
CONNECT_CLIENT_SECRET=connect-app-client-secret

# GitHub connection name in Auth0
AUTH0_CONNECTION=github
