{
  "name": "wormhole",
  "version": "1.0.0",
  "description": "Docker-based transparent HTTPS proxy sidecar",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm test && npm run build",
    "start": "node --import tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "generate-ca": "node --import tsx src/generate-ca.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test 'test/unit/**/*.test.ts'",
    "test:docker": "docker compose -f test/docker-compose.test.yml up --build --abort-on-container-exit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "node-forge": "^1.3.1",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-forge": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
